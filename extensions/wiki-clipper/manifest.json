{
  "manifest_version": 3,
  "name": "Kinic Wiki Clipper",
  "version": "0.1.0",
  "description": "Create Kinic Wiki pages from the current tab and export ChatGPT conversations.",
  "key": "",
  "action": {
    "default_title": "Create Kinic wiki page"
  },
  "options_page": "popup/popup.html",
  "background": {
    "service_worker": "dist/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["dist/content-ui.js"],
      "run_at": "document_start"
    }
  ],
  "permissions": ["storage", "tabs", "activeTab", "offscreen"],
  "host_permissions": [
    "https://wiki-generator.kinic.xyz/*",
    "https://id.ai/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://icp0.io/*",
    "https://*.icp0.io/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ]
}
