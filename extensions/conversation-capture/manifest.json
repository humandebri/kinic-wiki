{
  "manifest_version": 3,
  "name": "Kinic Conversation Capture",
  "version": "0.1.0",
  "description": "Capture the active ChatGPT conversation into a Kinic Wiki canister raw source.",
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Capture conversation"
  },
  "background": {
    "service_worker": "dist/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["dist/content-ui.js"],
      "run_at": "document_start"
    }
  ],
  "permissions": ["storage"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://icp0.io/*",
    "https://*.icp0.io/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ]
}
