{
  "rewrites": [
    {
      "source": "/dashboard/:databaseId",
      "destination": "/dashboard"
    },
    {
      "source": "/dashboard/:databaseId/:segments*",
      "destination": "/dashboard"
    },
    {
      "source": "/:databaseId",
      "destination": "/w"
    },
    {
      "source": "/:databaseId/:segments*",
      "destination": "/w"
    }
  ]
}
